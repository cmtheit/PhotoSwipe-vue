{
  "name": "photoswipe-vue",
  "version": "0.1.1",
  "main": "src/js/photoswipe.js",
  "style": "src/photoswipe.css",
  "type": "module",
  "types": "./dist/types/photoswipe.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/photoswipe.d.ts",
      "default": "./src/js/photoswipe.js"
    },
    "./lightbox": {
      "types": "./dist/types/lightbox/lightbox.d.ts",
      "default": "./src/js/lightbox/lightbox.js"
    },
    "./vue": {
      "types": "./src/vue/types.ts",
      "import": "./src/vue/PhotoSwipe.vue",
      "default": "./src/vue/PhotoSwipe.vue"
    },
    "./dist/photoswipe.css": "./src/photoswipe.css",
    "./photoswipe.css": "./src/photoswipe.css",
    "./style.css": "./src/photoswipe.css"
  },
  "typesVersions": {
    "*": {
      "lightbox": [
        "dist/types/lightbox/lightbox.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "README.zh_cn.md"
  ],
  "engines": {
    "node": ">= 0.12.0"
  },
  "scripts": {
    "build": "npm run build:css && npm run build:vue",
    "build:css": "copyfiles -f src/photoswipe.css dist/",
    "build:vue": "vite build --config vite.lib.config.js",
    "lint": "eslint src/js/**/*.js",
    "lint-auto-fix": "eslint src/js/**/*.js --fix",
    "tsc": "tsc",
    "dev": "vite",
    "dev:lan": "vite --host",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^6.0.2",
    "copyfiles": "^2.4.1",
    "eslint": "^8.16.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.26.0",
    "happy-dom": "^20.7.0",
    "image-size": "^1.1.1",
    "typescript": "^4.7.3",
    "vite": "^5.4.0",
    "vitest": "^4.0.18",
    "vue": "^3.5.13"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:cmtheit/PhotoSwipe-vue.git"
  },
  "keywords": [
    "gallery",
    "lightbox",
    "photo",
    "image",
    "touch",
    "swipe",
    "zoom"
  ],
  "author": "cmtheit (fork from Dmytro Semenov (https://dimsemenov.com))",
  "description": "Vue 3 reactive component for PhotoSwipe-style lightbox: data-driven slides, touch gestures, zoom, and open/close animations. TypeScript-friendly.",
  "license": "MIT"
}
